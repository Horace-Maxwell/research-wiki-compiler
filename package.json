{
  "name": "research-wiki-compiler",
  "version": "0.1.0",
  "description": "Local-first research wiki compiler for turning sources into a durable, reviewable Markdown knowledge base.",
  "author": "Horace <maxwelldhx@gmail.com>",
  "license": "Apache-2.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Horace-Maxwell/research-wiki-compiler.git"
  },
  "homepage": "https://github.com/Horace-Maxwell/research-wiki-compiler",
  "bugs": {
    "url": "https://github.com/Horace-Maxwell/research-wiki-compiler/issues"
  },
  "keywords": [
    "local-first",
    "research",
    "wiki",
    "markdown",
    "knowledge-base",
    "sqlite",
    "nextjs"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:navigation": "npm run build && playwright test tests/e2e/navigation-regression.spec.ts tests/e2e/dashboard-navigation-regression.spec.ts tests/e2e/topics-navigation-regression.spec.ts tests/e2e/runtime-stability-regression.spec.ts tests/e2e/repeated-use-stability.spec.ts tests/e2e/exhaustive-product-self-check.spec.ts",
    "test:e2e:headed": "npm run build && playwright test --headed",
    "env:check": "tsx scripts/check-environment.ts",
    "verify:routes": "node scripts/check-showcase-routes.mjs",
    "verify:fast": "npm run env:check && npm run lint && npm test",
    "verify:local": "npm run verify:fast && npm run build && npm run example:openclaw:validate && npm run verify:routes && npm run test:e2e:navigation",
    "verify:full": "npm run demo:reset && npm run showcase:openclaw && npm run verify:local",
    "demo:reset": "tsx scripts/seed-demo-workspace.ts",
    "example:openclaw": "npm run example:openclaw:build",
    "example:openclaw:reset": "tsx scripts/reset-openclaw-example.ts",
    "example:openclaw:build": "tsx scripts/generate-openclaw-example.ts --mode=reference",
    "example:openclaw:validate": "tsx scripts/validate-openclaw-example.ts",
    "example:openclaw:live": "tsx scripts/generate-openclaw-example.ts --mode=live",
    "example:openclaw:sync": "tsx scripts/generate-openclaw-example.ts --mode=reference --sync-snapshot",
    "showcase:openclaw": "npm run env:check && npm run example:openclaw:reset && npm run example:openclaw:build && npm run example:openclaw:validate && npm run example:openclaw:evaluate",
    "topic:init": "tsx scripts/init-topic-bootstrap.ts",
    "topic:build": "tsx scripts/build-topic-bootstrap.ts",
    "topic:validate": "tsx scripts/validate-topic-bootstrap.ts",
    "topic:evaluate": "tsx scripts/evaluate-topic-quality.ts",
    "example:openclaw:evaluate": "tsx scripts/evaluate-topic-quality.ts --example openclaw",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit check"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.7.0",
    "mdast-util-find-and-replace": "^3.0.2",
    "next": "16.2.2",
    "pino": "^10.3.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "simple-git": "^3.33.0",
    "tailwind-merge": "^3.5.0",
    "unified": "^11.0.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "jsdom": "^27.0.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
